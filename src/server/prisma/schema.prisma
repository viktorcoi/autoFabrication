generator client {
	provider = "prisma-client"
	output   = "../src/generated/prisma"
}

datasource db {
	provider = "postgresql"
}

model Role {
	id          Int    @id @default(autoincrement())
	name        String @unique
	description String?
	permissions Json
	createdAt   DateTime @default(now())
	updatedAt   DateTime @updatedAt
	users       User[]
}

model User {
	id           Int    @id @default(autoincrement())
	firstName    String
	lastName     String
	middleName   String?
	login        String @unique
	passwordHash String @map("password")
	avatarUrl    String? @map("avatar")
	roleId       Int
	createdAt    DateTime @default(now())
	updatedAt    DateTime @updatedAt
	role         Role @relation(fields: [roleId], references: [id], onDelete: Restrict, onUpdate: Cascade)

	@@index([roleId])
}
