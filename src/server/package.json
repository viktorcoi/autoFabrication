{
	"name": "server",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "tsx watch src/index.ts",
		"build": "tsc -p tsconfig.json",
		"start": "node dist/index.js",
		"lint": "tsc --noEmit -p tsconfig.json",
		"db:up": "docker compose up -d postgres",
		"db:down": "docker compose down",
		"prisma:generate": "prisma generate",
		"prisma:migrate": "prisma migrate dev --name init",
		"prisma:seed": "prisma db seed"
	},
	"dependencies": {
		"@prisma/adapter-pg": "^7.7.0",
		"@prisma/client": "^7.7.0",
		"bcrypt": "^6.0.0",
		"cookie": "^1.0.2",
		"cors": "^2.8.5",
		"dotenv": "^17.2.3",
		"express": "^5.1.0",
		"helmet": "^8.1.0",
		"jsonwebtoken": "^9.0.2",
		"multer": "^2.0.2",
		"pg": "^8.16.3",
		"pino-http": "^11.0.0",
		"zod": "^4.1.12"
	},
	"devDependencies": {
		"@types/bcrypt": "^6.0.0",
		"@types/cookie": "^0.6.0",
		"@types/cors": "^2.8.19",
		"@types/express": "^5.0.3",
		"@types/jsonwebtoken": "^9.0.10",
		"@types/multer": "^2.0.0",
		"@types/node": "^24.6.1",
		"prisma": "^7.7.0",
		"tsx": "^4.20.6",
		"typescript": "^5.9.3"
	}
}
